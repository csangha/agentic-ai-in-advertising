# Optimization Agent — Environment Variables
# Copy to .env and fill in your values

SECRET_NAME=campaign-mgmt/optimization-agent
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Database
DATABASE_URL=postgresql://campaign_user:password@localhost:5432/campaign_db

# MCP Guardrails Server
MCP_GUARDRAILS_ARN=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/guardrails-server

# Agent port
AGENT_PORT=9003
