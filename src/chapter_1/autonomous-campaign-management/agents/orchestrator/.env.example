# Campaign Orchestrator Agent — Environment Variables
# Copy to .env and fill in your values

SECRET_NAME=campaign-mgmt/agent-config
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# MCP Server ARNs (deployed on Bedrock AgentCore)
MCP_METRICS_ARN=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/metrics-server
MCP_GUARDRAILS_ARN=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/guardrails-server

# Amazon Ads MCP Server credentials
CLIENT_ID=your_amazon_ads_client_id
CLIENT_SECRET=your_amazon_ads_client_secret
REFRESH_TOKEN=your_amazon_ads_refresh_token

# Tool filter (comma-separated prefixes to include)
TOOL_FILTER=campaign_management,reporting,account_management

# Agent port
AGENT_PORT=9000
