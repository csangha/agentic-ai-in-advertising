# Monitoring Agent — Environment Variables
# Copy to .env and fill in your values

SECRET_NAME=campaign-mgmt/monitoring-agent
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Database
DATABASE_URL=postgresql://campaign_user:password@localhost:5432/campaign_db

# Redis (for caching latest metrics)
REDIS_ENDPOINT=redis://localhost:6379

# Monitoring cycle (minutes)
MONITORING_CYCLE_MINUTES=15

# Agent port
AGENT_PORT=9002
